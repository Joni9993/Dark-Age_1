# Server
PORT=3000

# PostgreSQL — z.B. postgresql://postgres:password@localhost:5432/darkages
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/darkages

# JWT — langer zufälliger String, z.B.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# SMTP (z.B. Brevo Free: 300 Mails/Tag, oder eigener Mailserver)
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=deine@email.de
SMTP_PASS=dein-smtp-passwort
SMTP_FROM=Dark Ages <noreply@deinedomain.de>

# Web Push — generieren mit: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=dein-vapid-public-key
VAPID_PRIVATE_KEY=dein-vapid-private-key
VAPID_SUBJECT=mailto:deine@email.de

# App URL (für Push-Notification Links)
APP_URL=https://deinedomain.de
