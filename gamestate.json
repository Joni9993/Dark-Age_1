{
  "sd": 1337,       // mapSeed: Generiert das Terrain und die Dörfer deterministisch
  "rn": 1,          // roundNum: Aktuelle Runde
  "cp": 0,          // currentPlayer: 0 (Spieler 1) oder 1 (Spieler 2)
  "df": null,       // draftPending: Falls ein Spieler gerade Pfeiler wählen muss (z.B. [1, 3] für Plünderer/Spionage)
  
  "p": [            // players: Array für beide Spieler
    { 
      "g": 0,       // gold
      "m": 0,       // material
      "f": [],      // factions: Gewählte Kultur-Pfeiler (0=Feudal, 1=Plünderer, 2=Spionage, 3=Gilden)
      "vc": 0       // villageCount: Zähler für eroberte Dörfer (triggert den Draft)
    },
    { "g": 0, "m": 0, "f": [], "vc": 0 }
  ],
  
  "v": {            // villages: Speichert nur die Änderungen zum Seed (Besitzer)
    "5,5": 0,       // Koordinate "x,y": Spieler ID (0 oder 1)
    "12,8": 1
  },
  
  "u": [            // units: Alle Einheiten auf dem Feld
    {
      "i": 1,       // id: Eindeutige ID der Einheit
      "p": 0,       // player: Besitzer (0 oder 1)
      "t": 0,       // type: 0=Schwert, 1=Bogen, 2=Pferd, etc.
      "x": 5,       // x-Koordinate
      "y": 6,       // y-Koordinate
      "h": 10,      // hp: Lebenspunkte (1-10)
      "a": 0        // acted: Hat diese Runde schon gehandelt? (0=Nein, 1=Ja)
    }
  ]
}
